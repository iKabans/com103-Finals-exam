hero_names = ["Layla", "Tigreal", "Gusion", "Kagura", "Chou"]
hero_roles = ["Marksman", "Tank", "Assassin", "Mage", "Fighter"]

ign = input("In-game name (IGN): ")
rank = input("Current rank: ")

print("\n==========================================")
print("   MOBILE LEGENDS -- HERO ROSTER")
print("==========================================")

for i in range(len(hero_names)):
    print(f" {i + 1}. {hero_names[i]:12} [{hero_roles[i]}]")

print("==========================================")

match_heroes = []
match_kdas = []
match_results = []
match_tags = []

wins = 0
losses = 0

for match in range(1, 5):

    print(f"\n--- MATCH {match} ---")

    hero_number = int(input("Hero number (0 to skip): "))

for match in range(1, 5):

    print(f"\n--- MATCH {match} ---")

    hero_number = int(input("Hero number (0 to skip): "))

    if hero_number == 0:
        continue

    if 1 <= hero_number <= 5:

        kills = int(input("Kills: "))
        deaths = int(input("Deaths: "))
        assists = int(input("Assists: "))
        result = input("Result (W/L): ").upper()

        if deaths == 0:
            deaths = 1

        kda = (kills + assists) / deaths

        if kda >= 5:
            if result == "W":
                tag = "DOMINATION!"
            else:
                tag = "Carried Hard"
        else:
            if result == "W":
                tag = "Team Effort"
            else:
                tag = "Better Luck Next Game"

        hero_name = hero_names[hero_number - 1]

        match_heroes.append(hero_name)
        match_kdas.append(kda)
        match_results.append(result)
        match_tags.append(tag)

        if result == "W":
            wins += 1
        else:
            losses += 1

matches_played = len(match_heroes)

if matches_played > 0:
    win_rate = int((wins / matches_played) * 100)
else:
    win_rate = 0

best_index = 0

if matches_played > 0:
    for i in range(len(match_kdas)):
        if match_kdas[i] > match_kdas[best_index]:
            best_index = i


print("\n=============================================")
print(f"     {ign} -- MATCH LOG ({rank})")
print("=============================================")
